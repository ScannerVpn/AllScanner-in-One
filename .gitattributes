# Normalize line endings for everyone who clones the repo.
# Windows batch/cmd/PowerShell scripts must use CRLF to run reliably.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Unix shell scripts must use LF.
*.sh    text eol=lf

# Source files: normalize to LF in the repo.
*.js    text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.md    text eol=lf

# Installer is tracked with Git LFS.
dist/VPN[[:space:]]Scanner[[:space:]]Suite[[:space:]]Setup[[:space:]]1.0.0.exe filter=lfs diff=lfs merge=lfs -text
